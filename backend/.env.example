# Copy to .env and adjust for local development
APP_NAME=FinGuard AI
APP_ENV=development
DEBUG=true

DATABASE_URL=postgresql+asyncpg://finguard:finguard@localhost:5432/finguard
DATABASE_URL_SYNC=postgresql+psycopg2://finguard:finguard@localhost:5432/finguard

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
